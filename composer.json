{
    "name": "kauan/php-core",
    "description": "High-Performance Systems Architecture with Hexagonal Design",
    "type": "project",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Core\\": "1-kernel-and-autoloader/",
            "Domain\\": "04-business-domain-logic/",
            "Infrastructure\\": "06-infrastructure-services/"
        }
    },
    "require": {
        "php": "^8.3",
        "laravel/octane": "^2.3",
        "spiral/roadrunner": "^2023.3",
        "php-di/php-di": "^7.0",
        "vlucas/phpdotenv": "^5.6",
        "monolog/monolog": "^3.5"
    },
    "require-dev": {
        "pestphp/pest": "^2.34",
        "phpstan/phpstan": "^1.10",
        "infection/infection": "^0.27",
        "mockery/mockery": "^1.6"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
