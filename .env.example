# --- CORE ENGINE CONFIG ---
APP_NAME=PHP-CORE
APP_ENV=local
APP_KEY=base64:$(openssl rand -base64 32)
APP_DEBUG=true
APP_URL=http://localhost

# --- RUNTIME (OCTANE/SWOOLE) ---
OCTANE_SERVER=swoole
SWOOLE_HTTP_PORT=8000
SWOOLE_HTTP_HOST=0.0.0.0

# --- DATABASE PERSISTENCE (03-data-persistence) ---
DB_CONNECTION=mysql
DB_HOST=mysql-persistence
DB_PORT=3306
DB_DATABASE=php_core_db
DB_USERNAME=root
DB_PASSWORD=root_password

# --- DISTRIBUTED CACHE ---
REDIS_HOST=redis-cache
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- INFRASTRUCTURE SERVICES (06-infrastructure) ---
AWS_ACCESS_KEY_ID=localstack
AWS_SECRET_ACCESS_KEY=localstack
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=storage-bucket
AWS_ENDPOINT=http://localstack-aws:4566

# --- SECURITY ---
AES_ENCRYPTION_KEY=32_CHARACTER_LONG_KEY_HERE
